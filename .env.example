# ═══════════════════════════════════════════════════════════════════════════
# CP'S Enterprise DCS - Environment Configuration Example
# 
# IMPORTANT: This file contains NO REAL SECRETS
# Copy to .env.local and fill in YOUR OWN VALUES
# NEVER commit .env, .env.local, or .env.prod to Git
# ═══════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────
# Application Environment
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
REACT_ENV=development
LOG_LEVEL=info

# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# 
# SECURITY: Use strong passwords (minimum 16 characters)
# Format: postgresql://user:password@host:port/database
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=dcs_dev
DATABASE_USER=dcs_user
DATABASE_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
DATABASE_POOL_SIZE=20
DATABASE_SSL=false

# For production, use:
# DATABASE_SSL=true
# DATABASE_POOL_SIZE=50

# ─────────────────────────────────────────────────────────────────────────────
# Redis Configuration
# ─────────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_DB=0
REDIS_POOL_SIZE=10

# ─────────────────────────────────────────────────────────────────────────────
# Kafka Configuration
# ─────────────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=dcs-app
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
# For production, use:
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_USERNAME=your-username
# KAFKA_SASL_PASSWORD=CHANGE_ME

# ─────────────────────────────────────────────────────────────────────────────
# Encryption Configuration
# 
# SECURITY: Master key must be stored in Vault, not here
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_ENCRYPTION=true
ENCRYPTION_ALGORITHM=AES-256-GCM
KEY_ROTATION_DAYS=90

# ─────────────────────────────────────────────────────────────────────────────
# HashiCorp Vault Configuration
# 
# Used for secrets management in production
# ─────────────────────────────────────────────────────────────────────────────
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=CHANGE_ME_USE_STRONG_UNIQUE_TOKEN
VAULT_SECRET_PATH=secret/dcs-dev
VAULT_TIMEOUT=30

# ─────────────────────────────────────────────────────────────────────────────
# Authentication & Security
# 
# SECURITY: Use strong, unique values for each environment
# ─────────────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING_MIN_32_CHARS
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=86400

# API authentication
API_KEY_PREFIX=sk_
ENABLE_API_KEY_AUTH=true
API_KEY_ROTATION_DAYS=30

# 2FA/MFA
ENABLE_MFA=true
MFA_ISSUER=DCS
MFA_WINDOW=1

# ─────────────────────────────────────────────────────────────────────────────
# Cloudflare Configuration
# 
# For deploying to Cloudflare Workers
# ─────────────────────────────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=CHANGE_ME_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=CHANGE_ME_API_TOKEN
CLOUDFLARE_WORKERS_SUBDOMAIN=dcs-dev

# ─────────────────────────────────────────────────────────────────────────────
# GitLab CI/CD Configuration
# 
# These should be set as Protected Variables in GitLab, not here
# ─────────────────────────────────────────────────────────────────────────────
# CI_REGISTRY_USER=your-gitlab-user
# CI_REGISTRY_PASSWORD=CHANGE_ME_GITLAB_TOKEN
# CI_REGISTRY=registry.gitlab.com

# ─────────────────────────────────────────────────────────────────────────────
# Email Configuration (if applicable)
# ─────────────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM=noreply@example.com
ENABLE_EMAIL=false

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring & Logging
# ─────────────────────────────────────────────────────────────────────────────
ENABLE_AUDIT_LOG=true
AUDIT_LOG_LEVEL=info
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# ─────────────────────────────────────────────────────────────────────────────
# CORS & Security Headers
# ─────────────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
CORS_CREDENTIALS=true
SECURITY_HEADERS_ENABLED=true
CSP_HEADER="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'"

# ─────────────────────────────────────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=15

# ─────────────────────────────────────────────────────────────────────────────
# Development Tools (dev environment only!)
# ─────────────────────────────────────────────────────────────────────────────
DEBUG_MODE=false
ALLOW_CORS_ALL=false
DISABLE_CSRF_CHECK=false
# ⚠️ NEVER enable these in production!

# ═══════════════════════════════════════════════════════════════════════════
# IMPORTANT REMINDERS
# ═══════════════════════════════════════════════════════════════════════════
#
# 1. NEVER commit this file with real secrets
# 2. Always use .env.local for local development
# 3. Store production secrets in:
#    - HashiCorp Vault (preferred)
#    - GitLab Protected Variables (for CI/CD)
#    - Kubernetes Secrets (if using K8s)
# 4. Rotate secrets regularly:
#    - API tokens: every 30 days
#    - Database passwords: every 90 days
#    - Encryption keys: on-demand (compromise only)
# 5. Use different secrets for each environment:
#    - dev, staging, production
# 6. Enable audit logging for all secret access
#
# ═══════════════════════════════════════════════════════════════════════════
