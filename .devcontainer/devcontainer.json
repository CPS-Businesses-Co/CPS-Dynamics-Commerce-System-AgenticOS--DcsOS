{
  "name": "CPS-Enterprise-Development-Environment",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.13",
      "installTools": true
    },
    "ghcr.io/wcgomes/devcontainer-features/agents-workspace:0": {
      "version": "latest"
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "1.24"
    },
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/docker-in-docker:1": {
      "version": "latest",
      "moby": true
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/common-utils:1": {
      "configureZshAsDefaultShell": true
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylint",
        "ms-python.black-formatter",
        "golang.go",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-azuretools.vscode-docker",
        "zxh404.vscode-proto3",
        "usernamehw.errorlens",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "ms-vscode.makefile-tools"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "go.gopath": "/go",
        "go.lintTool": "golangci-lint",
        "go.formatTool": "gofmt",
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "always"
        },
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "[go]": {
          "editor.defaultFormatter": "golang.go"
        },
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}/cps-enterprise-dcs/local-agent",
    "DCS_ENV": "development",
    "GOPRIVATE": "github.com/Ahmedhajjajofficial/*"
  },
  "forwardPorts": [
    3000,
    3001,
    5173,
    5432,
    6379,
    8200,
    9090,
    9092,
    50051,
    50052
  ],
  "portsAttributes": {
    "3000": {
      "label": "Admin Dashboard",
      "onAutoForward": "notify"
    },
    "3001": {
      "label": "Grafana Metrics",
      "onAutoForward": "silent"
    },
    "5173": {
      "label": "POS Interface (Vite)",
      "onAutoForward": "notify"
    },
    "8200": {
      "label": "HashiCorp Vault",
      "onAutoForward": "ignore"
    }
  },
  "postCreateCommand": "sudo apt-get update && sudo apt-get install -y make protobuf-compiler && make install && make build",
  "onCreateCommand": "git config --global --add safe.directory ${containerWorkspaceFolder}",
  "mounts": [
    "source=dcs-db-data,target=/var/lib/postgresql/data,type=volume",
    "source=dcs-vault-data,target=/vault/file,type=volume"
  ]
}
