# ═══════════════════════════════════════════════════════════════════════════════
# CP'S Enterprise DCS - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE
# ═══════════════════════════════════════════════════════════════════════════════

POSTGRES_USER=dcs_admin
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=dcs_eventstore
POSTGRES_PORT=5432

# ═══════════════════════════════════════════════════════════════════════════════
# REDIS
# ═══════════════════════════════════════════════════════════════════════════════

REDIS_PORT=6379
REDIS_PASSWORD=

# ═══════════════════════════════════════════════════════════════════════════════
# VAULT
# ═══════════════════════════════════════════════════════════════════════════════

VAULT_TOKEN=CHANGE_ME_VAULT_TOKEN
VAULT_PORT=8200

# ═══════════════════════════════════════════════════════════════════════════════
# KAFKA
# ═══════════════════════════════════════════════════════════════════════════════

KAFKA_PORT=9092

# ═══════════════════════════════════════════════════════════════════════════════
# MONITORING
# ═══════════════════════════════════════════════════════════════════════════════

PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ═══════════════════════════════════════════════════════════════════════════════
# AGENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════

# Regional Agent
REGIONAL_AGENT_ID=regional-001
REGION_ID=region-001
REGIONAL_RPC_PORT=12000
REGIONAL_RAFT_PORT=12001
REGIONAL_GRPC_PORT=50052

# Local Agent
LOCAL_AGENT_ID=local-001
BRANCH_ID=BR001
LOCAL_GRPC_PORT=50051

# ═══════════════════════════════════════════════════════════════════════════════
# POS INTERFACE
# ═══════════════════════════════════════════════════════════════════════════════

POS_PORT=3000

# ═══════════════════════════════════════════════════════════════════════════════
# SECURITY
# ═══════════════════════════════════════════════════════════════════════════════

# Master key for encryption (base64 encoded)
# Generate with: openssl rand -base64 32
DCS_MASTER_KEY=

# TLS Certificates
TLS_CERT_FILE=
TLS_KEY_FILE=
TLS_CA_FILE=

# ═══════════════════════════════════════════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════════════════════════════════════════

ENABLE_ENCRYPTION=true
ENABLE_AUDIT_LOG=true
ENABLE_FORECASTING=true
ENABLE_AGENT_SWARM=false

# ═══════════════════════════════════════════════════════════════════════════════
# PERFORMANCE
# ═══════════════════════════════════════════════════════════════════════════════

SYNC_INTERVAL=30
BATCH_SIZE=100
MAX_CONNECTIONS=1000
